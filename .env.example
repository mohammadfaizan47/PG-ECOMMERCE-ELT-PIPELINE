# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=ap-south-1

# RDS PostgreSQL
RDS_HOST=your_rds_endpoint_here
RDS_PORT=5432
RDS_DATABASE=ecommerce_db
RDS_USERNAME=postgres
RDS_PASSWORD=your_password_here

# AWS Secrets Manager
SECRETS_MANAGER_SECRET_NAME=your_secret_name_here

# Fivetran
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_API_SECRET=your_fivetran_api_secret_here
FIVETRAN_CONNECTOR_ID=your_connector_id_here

# Databricks
DATABRICKS_HOST=your_databricks_workspace_url_here
DATABRICKS_TOKEN=your_personal_access_token_here
DATABRICKS_JOB_ID=your_job_id_here

# Slack
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Airflow
AIRFLOW_UID=50000